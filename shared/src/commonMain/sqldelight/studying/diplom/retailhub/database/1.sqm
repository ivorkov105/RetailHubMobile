-- Миграция: Добавление таблиц для уведомлений и регистрации устройств
CREATE TABLE IF NOT EXISTS NotificationEntity (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    body TEXT NOT NULL,
    isRead INTEGER AS kotlin.Boolean NOT NULL DEFAULT 0,
    createdAt TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS DeviceEntity (
    id TEXT NOT NULL PRIMARY KEY,
    fcmToken TEXT NOT NULL
);
